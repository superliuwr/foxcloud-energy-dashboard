PORT=3000
HOST=0.0.0.0
DASHBOARD_TIME_ZONE=Australia/Sydney
DATA_PROVIDER=foxcloud

# FoxCloud mode. Keep these on the server only; never put them in browser code.
FOXCLOUD_BASE_URL=https://www.foxesscloud.com
FOXCLOUD_DEMO_MODE=false
FOXCLOUD_API_KEY=replace-with-your-foxcloud-api-key
FOXCLOUD_USERNAME=replace-with-your-foxcloud-username-if-needed
FOXCLOUD_PASSWORD=replace-with-your-foxcloud-password-if-needed
FOXCLOUD_DEVICE_SN=replace-with-your-device-serial-number-if-you-have-more-than-one-device
FOXCLOUD_TIMEOUT_MS=15000

# Local Modbus mode. Set DATA_PROVIDER=modbus to use these instead of FoxCloud.
MODBUS_HOST=replace-with-your-inverter-lan-ip
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_TIMEOUT_MS=3000
MODBUS_SAMPLE_INTERVAL_MS=60000
MODBUS_DEVICE_ID=local-modbus-inverter
MODBUS_STATION_NAME=Local Modbus inverter
MODBUS_INVERTER_MODEL=FoxESS H3 Smart
MODBUS_READ_ONLY=true

# SQLite backup. Docker maps /app/backups to ./backups on the host/NAS.
SQLITE_BACKUP_ENABLED=true
SQLITE_BACKUP_DIR=/app/backups
SQLITE_BACKUP_INTERVAL_MS=3600000
SQLITE_BACKUP_RETENTION_COUNT=72

DASHBOARD_USERNAME=replace-with-a-dashboard-login-name
DASHBOARD_PASSWORD=replace-with-a-strong-dashboard-password
DASHBOARD_USERS=Foxtester=replace-with-a-strong-test-password
