{
  "name": "foxcloud-energy-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Beginner-friendly FoxCloud battery dashboard with a protected backend proxy.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup-env.mjs",
    "dev": "tsx watch src/server.ts",
    "build": "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "node ./node_modules/typescript/lib/tsc.js --noEmit -p tsconfig.json",
    "metadata": "node scripts/update-build-metadata.mjs",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "modbus-serial": "^8.0.25"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
